---
import ContainerOuter from './ContainerOuter.astro'
import ContainerInner from './ContainerInner.astro'

interface Props {
  class?: string
  [key: string]: unknown
}
const { class: className, ...rest } = Astro.props
---

<ContainerOuter class={className} {...rest}>
  <ContainerInner>
    <slot />
  </ContainerInner>
</ContainerOuter>
