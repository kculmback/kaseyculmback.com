---
import BaseLayout from '../layouts/BaseLayout.astro'
import Container from '../components/Container.astro'
import GitHubIcon from '../components/GitHubIcon.astro'
import LinkedInIcon from '../components/LinkedInIcon.astro'

const currentYear = new Date().getFullYear().toString()

interface Role {
  company: string
  title: string
  logo: string
  start: string | { label: string; dateTime: string }
  end: string | { label: string; dateTime: string }
}

const resume: Role[] = [
  {
    company: 'EIG Technology',
    title: 'Senior Software Engineer',
    logo: '/images/logos/eigTechnology.png',
    start: 'Mar 2021',
    end: { label: 'Present', dateTime: currentYear },
  },
  {
    company: 'Aon',
    title: 'Software Engineer',
    logo: '/images/logos/aon.svg',
    start: 'Jan 2020',
    end: 'Mar 2021',
  },
  {
    company: '14Four',
    title: 'Web Developer',
    logo: '/images/logos/14four.jpeg',
    start: 'Feb 2018',
    end: 'Jan 2020',
  },
  {
    company: 'Two Barrels',
    title: 'Web Developer',
    logo: '/images/logos/2barrels.svg',
    start: 'Oct 2017',
    end: 'Feb 2018',
  },
]

function getLabel(val: string | { label: string; dateTime: string }): string {
  return typeof val === 'string' ? val : val.label
}

function getDateTime(val: string | { label: string; dateTime: string }): string {
  return typeof val === 'string' ? val : val.dateTime
}
---

<BaseLayout title="Kasey Culmback - Software Engineer">
  <Container class="mt-8">
    <div class="mx-auto grid max-w-xl grid-cols-1 gap-y-20 lg:max-w-none lg:grid-cols-2">
      <div class="flex flex-col">
        <h1 class="mb-6 text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100">
          Kasey Culmback,<br />Software Engineer.
        </h1>
        <p class="mb-8 text-base text-zinc-600 dark:text-zinc-400">
          I'm Kasey, a Software Engineer based in Mount Vernon, WA. I've been coding full-time since
          2017 and part-time even longer. I specialize in Front-End Engineering, with significant
          experience in React, Vue, and Typescript.
        </p>
        <div class="flex gap-6">
          <a
            href="https://www.linkedin.com/in/kculmback/"
            aria-label="Follow on LinkedIn"
            class="group -m-1 p-1"
          >
            <LinkedInIcon class="h-6 w-6 fill-zinc-500 transition group-hover:fill-zinc-600 dark:fill-zinc-400 dark:group-hover:fill-zinc-300" />
          </a>
          <a
            href="https://github.com/kculmback"
            aria-label="Follow on GitHub"
            class="group -m-1 p-1"
          >
            <GitHubIcon class="h-6 w-6 fill-zinc-500 transition group-hover:fill-zinc-600 dark:fill-zinc-400 dark:group-hover:fill-zinc-300" />
          </a>
        </div>
      </div>

      <div class="space-y-10 lg:pl-16 xl:pl-24">
        <div class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-700/40">
          <h2 class="flex text-sm font-semibold text-zinc-900 dark:text-zinc-100">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="h-6 w-6 flex-none"
            >
              <path
                d="M2.75 9.75a3 3 0 0 1 3-3h12.5a3 3 0 0 1 3 3v8.5a3 3 0 0 1-3 3H5.75a3 3 0 0 1-3-3v-8.5Z"
                class="fill-zinc-100 stroke-zinc-400 dark:fill-zinc-100/10 dark:stroke-zinc-500"
              />
              <path
                d="M3 14.25h6.249c.484 0 .952-.002 1.316.319l.777.682a.996.996 0 0 0 1.316 0l.777-.682c.364-.32.832-.319 1.316-.319H21M8.75 6.5V4.75a2 2 0 0 1 2-2h2.5a2 2 0 0 1 2 2V6.5"
                class="stroke-zinc-400 dark:stroke-zinc-500"
              />
            </svg>
            <span class="ml-3">Work</span>
          </h2>
          <ol class="mt-6 space-y-4">
            {
              resume.map((role) => (
                <li class="flex gap-4">
                  <div class="relative mt-1 flex h-10 w-10 flex-none items-center justify-center rounded-full shadow-md shadow-zinc-800/5 ring-1 ring-zinc-900/5 dark:border dark:border-zinc-700/50 dark:bg-zinc-800 dark:ring-0">
                    <img
                      src={role.logo}
                      alt=""
                      class="h-7 w-7 rounded-full object-contain"
                    />
                  </div>
                  <dl class="flex flex-auto flex-wrap gap-x-2">
                    <dt class="sr-only">Company</dt>
                    <dd class="w-full flex-none text-sm font-medium text-zinc-900 dark:text-zinc-100">
                      {role.company}
                    </dd>
                    <dt class="sr-only">Role</dt>
                    <dd class="text-xs text-zinc-500 dark:text-zinc-400">{role.title}</dd>
                    <dt class="sr-only">Date</dt>
                    <dd
                      class="ml-auto text-xs text-zinc-400 dark:text-zinc-500"
                      aria-label={`${getLabel(role.start)} until ${getLabel(role.end)}`}
                    >
                      <time datetime={getDateTime(role.start)}>{getLabel(role.start)}</time>{' '}
                      <span aria-hidden="true">—</span>{' '}
                      <time datetime={getDateTime(role.end)}>{getLabel(role.end)}</time>
                    </dd>
                  </dl>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>
